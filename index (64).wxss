.summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 22rpx;
  padding: 28rpx;
}
.summary-title {
  color: #23352A;
  font-size: 34rpx;
  font-weight: 800;
}
.summary-sub {
  margin-top: 8rpx;
  color: #6E7B72;
  font-size: 24rpx;
}
.summary button {
  width: 130rpx;
  height: 62rpx;
  line-height: 62rpx;
  color: #357A4A;
  background: #E8F6EA;
  border-radius: 999rpx;
  font-size: 24rpx;
}
.order-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
}
.cover {
  width: 118rpx;
  height: 118rpx;
  overflow: hidden;
  flex: 0 0 118rpx;
  text-align: center;
  line-height: 118rpx;
  background: #E8F6EA;
  border-radius: 20rpx;
}
.cover image {
  width: 100%;
  height: 100%;
}
.info {
  min-width: 0;
  flex: 1;
}
.name {
  color: #23352A;
  font-size: 30rpx;
  font-weight: 700;
}
.desc {
  margin-top: 8rpx;
  color: #6E7B72;
  font-size: 24rpx;
}
.counter {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.counter button {
  width: 54rpx;
  height: 54rpx;
  padding: 0;
  line-height: 50rpx;
  color: #357A4A;
  background: #E8F6EA;
  border-radius: 50%;
}
.counter text {
  min-width: 34rpx;
  text-align: center;
  font-weight: 700;
}
