.row {
  display: grid;
  grid-template-columns: 1fr 1fr 58rpx 58rpx 66rpx;
  gap: 10rpx;
  margin-bottom: 14rpx;
}
input {
  height: 72rpx;
  padding: 0 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #DDE9E0;
  border-radius: 12rpx;
}
button {
  height: 72rpx;
  padding: 0;
  line-height: 72rpx;
  color: #357A4A;
  background: #DFF3E2;
  font-size: 24rpx;
}
.add {
  width: 100%;
  color: #FFFFFF;
  background: #69B96B;
  border-radius: 999rpx;
}
